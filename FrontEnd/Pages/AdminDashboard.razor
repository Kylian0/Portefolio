@page "/admin"
@using FrontEnd.Models
@using FrontEnd.Services
@inject IAdminAccessService AdminAccess
@inject IProjectApiService ProjectService
@inject IAdminMessageService MessageService
@inject NavigationManager Navigation

<PageTitle>Tableau de bord | Administration</PageTitle>

@if (AdminAccess.IsAuthenticated)
{
    <main class="admin-dashboard">
        <aside class="admin-sidebar">
            <a class="admin-sidebar__brand" href="/admin">Kylian <span>Admin</span></a>
            <nav aria-label="Navigation de l'administration">
                <a class="is-active" href="/admin">Vue d'ensemble</a>
                <a href="/admin/projects">Projets</a>
                <a href="/admin/technologies">Technologies</a>
                <a href="/admin/media">Médiathèque</a>
                <a href="/admin/messages">Messages</a>
                <a href="/">Voir le portfolio</a>
            </nav>
        </aside>

        <div class="admin-main admin-overview">
            <header class="admin-header admin-overview__header">
                <div>
                    <p class="admin-eyebrow">Vue d'ensemble</p>
                    <h1>Bonjour Kylian</h1>
                    <p>Voici les informations importantes de votre portfolio.</p>
                </div>
                <button type="button" @onclick="HandleLogout">Se déconnecter</button>
            </header>

            <section class="admin-stats admin-overview__stats" aria-label="Statistiques principales">
                <a href="/admin/projects"><span>Projets</span><strong>@projects.Count</strong><small>Gérer les réalisations →</small></a>
                <a href="/admin/messages"><span>Messages reçus</span><strong>@messages.Count</strong><small>Consulter la messagerie →</small></a>
                <a href="/admin/messages"><span>Messages non lus</span><strong>@UnreadCount</strong><small>@UnreadSummary</small></a>
                <a href="/admin/projects"><span>Projets publiés</span><strong>@projects.Count(x => x.Status == "published")</strong><small>Visibles publiquement</small></a>
            </section>

            <section class="admin-quick-actions" aria-labelledby="quick-actions-title">
                <div><p class="admin-eyebrow">Raccourcis</p><h2 id="quick-actions-title">Accès rapides</h2></div>
                <div class="admin-quick-actions__links">
                    <a href="/admin/projects"><strong>Gérer les projets</strong><span>Modifier les cartes et la documentation</span></a>
                    <a href="/admin/technologies"><strong>Gérer les technologies</strong><span>Catégories, technologies et associations</span></a>
                    <a href="/admin/messages"><strong>Ouvrir les messages</strong><span>Consulter et traiter les prises de contact</span></a>
                    <a href="/" target="_blank"><strong>Voir le portfolio</strong><span>Ouvrir le site public dans un nouvel onglet</span></a>
                </div>
            </section>

            <div class="admin-overview__columns">
                <section class="admin-panel admin-overview-panel">
                    <div class="admin-panel__heading">
                        <div><h2>Derniers messages</h2><p>Les prises de contact les plus récentes.</p></div>
                        <a href="/admin/messages">Tout afficher</a>
                    </div>
                    <ul class="admin-overview-messages">
                        @foreach (var message in LatestMessages)
                        {
                            <li class="@(message.IsRead ? null : "is-unread")">
                                <span class="admin-overview-avatar" aria-hidden="true">@GetInitials(message.SenderName)</span>
                                <div><strong>@message.SenderName</strong><span>@message.Subject</span></div>
                                <time datetime="@message.ReceivedAt.ToString("O")">@FormatRelativeDate(message.ReceivedAt)</time>
                            </li>
                        }
                    </ul>
                </section>

                <section class="admin-panel admin-overview-panel">
                    <div class="admin-panel__heading">
                        <div><h2>Projets récents</h2><p>Aperçu des contenus administrables.</p></div>
                        <a href="/admin/projects">Tout afficher</a>
                    </div>
                    <ul class="admin-overview-projects">
                        @foreach (var project in LatestProjects)
                        {
                            <li>
                                <img src="@(project.ThumbnailUrl ?? "images/project-placeholder.svg")" alt="" />
                                <div><strong>@project.Title</strong><span>@project.Status · modifié le @project.UpdatedAt.ToString("dd/MM/yyyy")</span></div>
                                <a href="@($"/projects/{project.Slug}?admin=true")" aria-label="Ouvrir la documentation du projet @project.Title">→</a>
                            </li>
                        }
                    </ul>
                </section>
            </div>

        </div>
    </main>
}

@code {
    private IReadOnlyList<ProjectApiDto> projects = [];
    private IReadOnlyList<AdminMessage> messages = [];
    private int UnreadCount => messages.Count(message => !message.IsRead);
    private string UnreadSummary => UnreadCount == 0 ? "Tout est à jour" : "À consulter rapidement";
    private IEnumerable<AdminMessage> LatestMessages => messages.OrderByDescending(message => message.ReceivedAt).Take(3);
    private IEnumerable<ProjectApiDto> LatestProjects => projects.OrderByDescending(x => x.UpdatedAt).Take(3);

    protected override async Task OnInitializedAsync()
    {
        await AdminAccess.InitializeAsync();
        if (!AdminAccess.IsAuthenticated) { Navigation.NavigateTo("/admin/login", replace: true); return; }
        projects = await ProjectService.GetAllAsync();
        messages = await MessageService.GetAllAsync();
    }

    private static string GetInitials(string name) => string.Concat(name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(part => char.ToUpperInvariant(part[0])));

    private static string FormatRelativeDate(DateTime date)
    {
        if (date.Date == DateTime.Today) return "Aujourd'hui";
        if (date.Date == DateTime.Today.AddDays(-1)) return "Hier";
        return date.ToString("dd/MM/yyyy");
    }

    private async Task HandleLogout()
    {
        await AdminAccess.SignOutAsync();
        Navigation.NavigateTo("/admin/login", replace: true);
    }
}
