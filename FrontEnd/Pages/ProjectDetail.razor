@page "/projects/{Slug}"
@inject IAdminAccessService AdminAccess
@inject IProjectDocumentationService DocumentationService
@inject NavigationManager Navigation

<PageTitle>@ProjectTitle | Portfolio</PageTitle>

<main class="project-document-page">
    <article class="project-document">
        <header class="project-document__header">
            <a class="project-document__back" href="/projects">← Retour aux projets</a>
            @if (AdminMode && AdminAccess.IsAuthenticated)
            {
                <div class="project-document__admin-bar">
                    <span>Mode administration</span>
                    <button type="button" @onclick="ToggleEditMode">@(editMode ? "Fermer l’éditeur" : "Modifier")</button>
                </div>
            }

            @if (data?.Project is { } project)
            {
                <p class="project-document__category">@(data.Document?.Title ?? "Étude de cas")</p>
                <h1>@project.Title</h1>
                <p class="project-document__lead">@project.ShortDescription</p>
                <dl class="project-document__metadata">
                    <div><dt>Projet de</dt><dd>Kylian</dd></div>
                    <div><dt>Statut</dt><dd>@GetStatusLabel(project.Status)</dd></div>
                    <div><dt>Année</dt><dd>@GetProjectYear(project)</dd></div>
                </dl>
                @if (data.Technologies.Count > 0)
                {
                    <div class="project-document__technology-section">
                        <h2>Technologies</h2>
                        <ul class="project-document__technologies" aria-label="Technologies du projet">
                            @foreach (var technology in data.Technologies)
                            {
                                <li class="@(technology.IsPrimary ? "project-document__technology--primary" : null)">
                                    @if (technology.IsPrimary)
                                    {
                                        <span aria-hidden="true">★</span>
                                    }
                                    <strong>@GetTechnologyName(technology)</strong>
                                    @if (!string.IsNullOrWhiteSpace(technology.CategoryName))
                                    {
                                        <small>@technology.CategoryName</small>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }
                else if (data.TechnologyLoadFailed)
                {
                    <p class="project-document__technology-error" role="status">Les technologies sont temporairement indisponibles.</p>
                }
            }
            else
            {
                <p class="project-document__category">Documentation</p>
                <h1>@ProjectTitle</h1>
            }
        </header>

        @if (isLoading)
        {
            <section class="project-document__state" aria-live="polite">
                <h2>Chargement de la documentation…</h2>
                <p>Le contenu du projet est en cours de récupération.</p>
            </section>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <section class="project-document__state" role="alert">
                <h2>Documentation indisponible</h2>
                <p>@errorMessage</p>
                <button type="button" @onclick="LoadDocumentationAsync">Réessayer</button>
            </section>
        }
        else if (data?.Project is null)
        {
            <section class="project-document__state">
                <h2>Projet introuvable</h2>
                <p>Ce projet n’existe pas ou n’est plus disponible.</p>
            </section>
        }
        else if (AdminMode && AdminAccess.IsAuthenticated && editMode)
        {
            <ProjectDocumentationEditor Data="data" OnChanged="LoadDocumentationAsync" />
        }
        else if (data.Document is null)
        {
            <section class="project-document__state">
                <h2>Aucune documentation disponible</h2>
                <p>La documentation de ce projet sera publiée prochainement.</p>
            </section>
        }
        else if (data.Blocks.Count == 0)
        {
            <section class="project-document__state">
                <h2>Documentation vide</h2>
                <p>Le document existe, mais aucun contenu n’a encore été ajouté.</p>
            </section>
        }
        else
        {
            @foreach (var block in data.Blocks)
            {
                <ProjectDocumentBlockRenderer Block="@block" Media="@data.Media" @key="block.Id" />
            }
        }

        @if (!isLoading && string.IsNullOrEmpty(errorMessage) && data?.Learnings.Count > 0)
        {
            <section class="project-learnings" aria-labelledby="project-learnings-title">
                <p class="project-document__category">Retour d’expérience</p>
                <h2 id="project-learnings-title">Ce que j’ai appris</h2>
                <ul>
                    @foreach (var learning in data.Learnings)
                    {
                        <li @key="learning.Id">@learning.Content</li>
                    }
                </ul>
            </section>
        }
        else if (!isLoading && string.IsNullOrEmpty(errorMessage) && data?.LearningLoadFailed == true)
        {
            <p class="project-learnings__error" role="status">Les apprentissages sont temporairement indisponibles.</p>
        }

    </article>
</main>

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "admin")]
    public bool AdminMode { get; set; }

    private ProjectDocumentationData? data;
    private bool isLoading = true;
    private bool editMode;
    private string? errorMessage;

    private string ProjectTitle => data?.Project?.Title ?? "Présentation du projet";

    protected override async Task OnParametersSetAsync()
    {
        if (AdminMode && !AdminAccess.IsAuthenticated)
        {
            Navigation.NavigateTo("/admin/login", replace: true);
            return;
        }

        await LoadDocumentationAsync();
    }

    private async Task LoadDocumentationAsync()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            data = await DocumentationService.GetByProjectSlugAsync(Slug);
        }
        catch (Exception)
        {
            errorMessage = "Vérifiez que l'API est démarrée, puis réessayez.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleEditMode() => editMode = !editMode;

    private static string GetStatusLabel(string status) => status switch
    {
        "published" => "Publié",
        "draft" => "Brouillon",
        "archived" => "Archivé",
        _ => status
    };

    private static int GetProjectYear(ProjectApiDto project) =>
        project.StartedAt?.Year ?? project.PublishedAt?.Year ?? project.CreatedAt.Year;

    private static string GetTechnologyName(ProjectTechnologyApiDto technology) =>
        string.IsNullOrWhiteSpace(technology.TechnologyName) ? "Technologie non renseignée" : technology.TechnologyName;
}
