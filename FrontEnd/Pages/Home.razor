@page "/"
@inject IProjectApiService ProjectApiService

<PageTitle>Kylian Garnier — Développeur logiciel &amp; Game Programming</PageTitle>

<main class="home-page">
    <section class="hero" aria-labelledby="hero-title">
        <div class="hero__content">
            <p class="home-eyebrow">Bonjour, je suis Kylian</p>
            <h1 id="hero-title">Je construis mon parcours vers le Game Programming.</h1>
            <p class="hero__description">
                J'ai 21 ans et mon objectif est de devenir Game Programmer. Je développe mes compétences en
                programmation de jeux vidéo tout en cultivant une solide polyvalence en développement logiciel, web et mobile.
            </p>

            <div class="hero__actions">
                <a class="button button--primary" href="/projects">Découvrir mes projets</a>
                <a class="button button--secondary" href="/contact">Discutons ensemble</a>
            </div>

            <ul class="hero__highlights" aria-label="Informations principales">
                <li><strong>21 ans</strong><span>passionné depuis toujours</span></li>
                <li><strong>1 objectif</strong><span>le Game Programming</span></li>
                <li><strong>100 %</strong><span>curieux et impliqué</span></li>
            </ul>
        </div>

        <div class="hero__visual" aria-hidden="true">
            <div class="hero__code-window">
                <span class="hero__window-bar"></span>
                <code>
                    <span>public</span> Developer Me =&gt; <span>new</span>()<br />
                    {<br />
                    &nbsp;&nbsp;Curious = <strong>true</strong>,<br />
                    &nbsp;&nbsp;Focused = <strong>true</strong><br />
                    };
                </code>
            </div>
        </div>
    </section>

    <section class="home-section about-section" aria-labelledby="about-title">
        <div class="section-heading">
            <p class="home-eyebrow">À propos</p>
            <h2 id="about-title">Une passion devenue un projet professionnel</h2>
        </div>
        <div class="about-section__content">
            <p>
                Passionné par l'informatique et les jeux vidéo depuis mon plus jeune âge, j'ai naturellement eu
                envie de comprendre comment les logiciels et les univers interactifs étaient créés. Cette curiosité
                m'a conduit vers le développement pour transformer ce qui m'anime depuis toujours en métier.
            </p>
            <p>
                Aujourd'hui, je souhaite orienter progressivement mon parcours vers la programmation de jeux vidéo.
                Mes projets en développement logiciel, web et mobile complètent cette spécialisation en renforçant
                ma rigueur, ma capacité à résoudre des problèmes et ma compréhension globale du code.
            </p>
        </div>
    </section>

    <section class="home-section skills-section" aria-labelledby="skills-title">
        <div class="section-heading section-heading--centered">
            <p class="home-eyebrow">Compétences</p>
            <h2 id="skills-title">Le Game Programming au cœur d'un profil polyvalent</h2>
            <p>Une orientation principale soutenue par des compétences complémentaires en développement logiciel.</p>
        </div>

        <div class="skills-grid">
            <article class="skill-card">
                <span class="skill-card__number">01</span>
                <h3>Game Programming</h3>
                <p>Apprentissage de la programmation de gameplay, des mécaniques de jeu et des systèmes interactifs.</p>
                <ul><li>Gameplay</li><li>Logique de jeu</li><li>Prototypage</li></ul>
            </article>
            <article class="skill-card">
                <span class="skill-card__number">02</span>
                <h3>Développement web</h3>
                <p>Création d'interfaces responsives et d'applications structurées, du navigateur jusqu'à l'API.</p>
                <ul><li>Blazor WebAssembly</li><li>ASP.NET Core</li><li>CSS responsive</li></ul>
            </article>
            <article class="skill-card">
                <span class="skill-card__number">03</span>
                <h3>Logiciel et mobile</h3>
                <p>Développement d'applications et exploration d'interfaces adaptées à différents usages et écrans.</p>
                <ul><li>Architecture logicielle</li><li>Interfaces mobiles</li><li>Expérience utilisateur</li></ul>
            </article>
        </div>
    </section>

    <section class="home-section featured-projects" aria-labelledby="projects-title">
        <div class="section-heading section-heading--with-action">
            <div>
                <p class="home-eyebrow">Aperçu des projets</p>
                <h2 id="projects-title">Des réalisations pour apprendre et expérimenter</h2>
            </div>
            <a class="text-link" href="/projects">Voir tous les projets →</a>
        </div>

        @if (isLoadingProjects)
        {
            <p role="status">Chargement du projet...</p>
        }
        else if (featuredProjects.Count > 0)
        {
            <div class="featured-projects__grid">
                @foreach (var project in featuredProjects)
                {
                    <ProjectCard Title="@project.Title"
                                 Description="@project.ShortDescription"
                                 DetailUrl="@($"/projects/{project.Slug}")"
                                 ImageUrl="@(string.IsNullOrWhiteSpace(project.ThumbnailUrl) ? PlaceholderImage : project.ThumbnailUrl)"
                                 ImageAlt="@($"Aperçu du projet {project.Title}")"
                                 Variant="compact" />
                }
            </div>
        }
        else
        {
            <p>Aucun projet publié n'est disponible pour le moment.</p>
        }
    </section>

    <section class="home-section approach-section" aria-labelledby="approach-title">
        <div class="section-heading">
            <p class="home-eyebrow">Ma manière d'apprendre</p>
            <h2 id="approach-title">Comprendre, expérimenter et progresser</h2>
        </div>
        <ol class="approach-list">
            <li>
                <span>01</span>
                <div><h3>Comprendre</h3><p>Analyser le besoin et les contraintes avant de commencer à construire.</p></div>
            </li>
            <li>
                <span>02</span>
                <div><h3>Expérimenter</h3><p>Tester des solutions, confronter mes idées au réel et apprendre en pratiquant.</p></div>
            </li>
            <li>
                <span>03</span>
                <div><h3>Progresser</h3><p>Tirer parti des résultats et des retours pour améliorer chaque nouvelle version.</p></div>
            </li>
        </ol>
    </section>

    <section class="home-cta" aria-labelledby="cta-title">
        <p class="home-eyebrow">Échangeons</p>
        <h2 id="cta-title">Envie de discuter jeux vidéo ou développement logiciel ?</h2>
        <p>Une opportunité junior, un projet à partager ou simplement un sujet technique à évoquer : n'hésitez pas à me contacter.</p>
        <div class="hero__actions">
            <a class="button button--light" href="/contact">Me contacter</a>
            <a class="button button--outline-light" href="/projects">Explorer mes projets</a>
        </div>
    </section>
</main>

@code {
    private const string PlaceholderImage = "images/project-placeholder.svg";
    private readonly List<ProjectApiDto> featuredProjects = [];
    private bool isLoadingProjects = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var projects = await ProjectApiService.GetAllAsync();
            featuredProjects.AddRange(projects
                .Where(project => string.Equals(project.Status, "published", StringComparison.OrdinalIgnoreCase))
                .Take(3));
        }
        catch
        {
            featuredProjects.Clear();
        }
        finally
        {
            isLoadingProjects = false;
        }
    }

}
