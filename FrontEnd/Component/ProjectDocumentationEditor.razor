@using TinyMCE.Blazor
@implements IDisposable
@inject IProjectDocumentationService DocumentationService
@inject IMediaApiService MediaApiService
@inject IProjectApiService ProjectApiService
@inject DocumentBlockHtmlConverter Converter
@inject IJSRuntime JSRuntime
@inject IConfiguration Configuration

<section class="wysiwyg-editor" aria-label="Éditeur visuel de documentation">
    <InputFile id="documentation-image-upload" class="wysiwyg-editor__hidden-upload" OnChange="UploadImageAsync" accept="image/jpeg,image/png,image/webp,image/gif" />
    <InputFile id="documentation-video-upload" class="wysiwyg-editor__hidden-upload" OnChange="UploadVideoAsync" accept="video/mp4,video/webm" />
    @if (Data.Document is null)
    {
        <div class="documentation-editor__empty"><h2>Aucune documentation</h2><p>Créez un document pour commencer la rédaction.</p><button type="button" disabled="@isSaving" @onclick="CreateDocumentAsync">Créer la documentation</button></div>
    }
    else
    {
        <div class="wysiwyg-editor__commandbar">
            <div class="wysiwyg-media-actions">
                <span class="wysiwyg-editor__commandbar-spacer"></span>
                <div class="wysiwyg-media-actions__save"><button type="button" disabled="@(!isDirty || isSaving)" @onclick="CancelAsync">Annuler</button><button type="button" class="admin-primary-button" disabled="@isSaving" @onclick="SaveAsync">@(isSaving ? "Enregistrement…" : "Enregistrer")</button></div>
            </div>
        </div>

        <label class="wysiwyg-editor__title"><span>Titre du document</span><input maxlength="200" value="@title" @oninput="OnTitleChanged" /></label>

        <div class="wysiwyg-editor__page">
            <Editor Id="portfolio-document-editor"
                    Value="@html"
                    ValueChanged="OnHtmlChanged"
                    LicenseKey="gpl"
                    ScriptSrc="/lib/tinymce/tinymce.min.js"
                    Conf="@EditorConfiguration" />
        </div>

        <footer class="wysiwyg-editor__footer">
            <button type="button" class="admin-danger-button" disabled="@isSaving" @onclick="DeleteDocumentAsync">Supprimer la documentation</button>
            <small>L’aperçu TinyMCE utilise les mêmes styles de contenu ; le HTML sera nettoyé côté serveur avant publication.</small>
            <button type="button" class="admin-primary-button" disabled="@isSaving" @onclick="SaveAsync">@(isSaving ? "Enregistrement…" : "Enregistrer les modifications")</button>
        </footer>
    }

    @if (errors.Count > 0) { <div class="documentation-editor__errors" role="alert">@foreach (var error in errors) { <p>@error</p> }</div> }
    @if (!string.IsNullOrWhiteSpace(successMessage)) { <p class="admin-modal-message" role="status">@successMessage</p> }
</section>
<MediaLibraryPicker Open="@pickerOpen" Media="pickerMedia" Projects="pickerProjects" MediaType="@pickerType" Multiple="@pickerMultiple" OnSelected="InsertMediaAsync" OnCancelled="ClosePicker" />

@code {
    [Parameter, EditorRequired] public ProjectDocumentationData Data { get; set; } = default!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private readonly List<string> errors = [];
    private string html = string.Empty;
    private string originalHtml = string.Empty;
    private string title = "Documentation";
    private string originalTitle = "Documentation";
    private string? successMessage;
    private bool pickerOpen, pickerMultiple;
    private string pickerType = "image";
    private IReadOnlyList<MediaApiDto> pickerMedia = [];
    private IReadOnlyList<ProjectApiDto> pickerProjects = [];
    private bool isDirty;
    private bool isSaving;
    private bool initialized;
    private string DraftKey => $"portfolio-document-draft-{Data.Project?.Id}";

    private Dictionary<string, object> EditorConfiguration => new()
    {
        ["height"] = 720,
        ["menubar"] = false,
        ["plugins"] = "advlist autolink lists link image charmap preview anchor searchreplace visualblocks code fullscreen insertdatetime media table help wordcount codesample portfoliomedia",
        ["external_plugins"] = new Dictionary<string, string> { ["portfoliomedia"] = "/js/portfolio-media-plugin.js" },
        ["toolbar"] = "undo redo | blocks fontsize | bold italic underline strikethrough | forecolor backcolor | alignleft aligncenter alignright alignjustify | outdent indent | bullist numlist | portfolioimage portfoliogallery portfoliovideo | link table blockquote codesample hr | removeformat code preview fullscreen",
        ["toolbar_mode"] = "sliding",
        ["toolbar_sticky"] = false,
        ["skin"] = "oxide",
        ["content_css"] = "default",
        ["promotion"] = false,
        ["branding"] = false,
        ["automatic_uploads"] = false,
        ["paste_data_images"] = false,
        ["convert_unsafe_embeds"] = true,
        ["valid_elements"] = "h1,h2,h3,h4,h5,h6,p,div,span,strong,b,em,i,u,s,strike,ul,ol,li,a[href|target|rel|class|data-media-id],blockquote,table,thead,tbody,tfoot,tr,th,td,pre[data-language],code,hr,img[src|alt|title|data-caption|data-media-id],figure[class],figcaption,video[src|controls|title|data-media-id],source[src],br",
        ["content_style"] = "body{max-width:760px;margin:2rem auto;padding:2rem;font-family:system-ui,sans-serif;line-height:1.75;}img,video{max-width:100%;height:auto;}"
    };

    protected override void OnParametersSet()
    {
        if (initialized) return;
        originalHtml = html = Converter.ToEditableHtml(Data.Blocks);
        originalTitle = title = Data.Document?.Title ?? "Documentation";
        initialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || Data.Document is null) return;
        mediaPickerReference = DotNetObjectReference.Create(this);
        await JSRuntime.InvokeVoidAsync("documentationEditor.registerMediaPicker", mediaPickerReference);
        var draft = await JSRuntime.InvokeAsync<string?>("documentationEditor.loadDraft", DraftKey);
        if (!string.IsNullOrWhiteSpace(draft) && draft != originalHtml) { html = draft; await MarkDirtyAsync(); StateHasChanged(); }
    }

    private async Task OnHtmlChanged(string value) { html = value; await JSRuntime.InvokeVoidAsync("documentationEditor.saveDraft", DraftKey, html); await MarkDirtyAsync(); }
    private async Task OnTitleChanged(ChangeEventArgs args) { title = args.Value?.ToString() ?? string.Empty; await MarkDirtyAsync(); }
    private async Task MarkDirtyAsync() { if (isDirty) return; isDirty = true; successMessage = null; await JSRuntime.InvokeVoidAsync("documentationEditor.enableLeaveWarning"); }

    private async Task CreateDocumentAsync() => await RunAsync(async () => { await DocumentationService.CreateDocumentAsync(new() { ProjectId = Data.Project!.Id, Title = "Documentation" }); await OnChanged.InvokeAsync(); });
    private async Task SaveAsync() => await RunAsync(async () => { await DocumentationService.SynchronizeAsync(Data.Document!.Id, title, html); originalHtml = html; originalTitle = title; isDirty = false; await JSRuntime.InvokeVoidAsync("documentationEditor.clearDraft", DraftKey); await JSRuntime.InvokeVoidAsync("documentationEditor.disableLeaveWarning"); successMessage = "Documentation enregistrée et nettoyée."; await OnChanged.InvokeAsync(); });
    private async Task CancelAsync() { html = originalHtml; title = originalTitle; isDirty = false; errors.Clear(); await JSRuntime.InvokeVoidAsync("documentationEditor.clearDraft", DraftKey); await JSRuntime.InvokeVoidAsync("documentationEditor.disableLeaveWarning"); }
    private async Task DeleteDocumentAsync() { if (!await JSRuntime.InvokeAsync<bool>("confirm", "Supprimer cette documentation et tous ses blocs ?")) return; await RunAsync(async () => { await DocumentationService.DeleteDocumentAsync(Data.Document!.Id); await JSRuntime.InvokeVoidAsync("documentationEditor.clearDraft", DraftKey); await JSRuntime.InvokeVoidAsync("documentationEditor.disableLeaveWarning"); await OnChanged.InvokeAsync(); }); }

    private void OpenPicker(string type, bool multiple) { pickerType = type; pickerMultiple = multiple; pickerOpen = true; }
    [JSInvokable]
    public async Task OpenMediaPickerFromTinyMce(string type, bool multiple)
    {
        if (multiple)
        {
            try
            {
                var mediaTask = MediaApiService.GetAllAsync();
                var projectsTask = ProjectApiService.GetAllAsync();
                await Task.WhenAll(mediaTask, projectsTask);
                pickerMedia = await mediaTask;
                pickerProjects = await projectsTask;
            }
            catch
            {
                pickerMedia = Data.Media;
                pickerProjects = Data.Project is null ? [] : [Data.Project];
            }
        }
        else
        {
            pickerMedia = Data.Media;
            pickerProjects = Data.Project is null ? [] : [Data.Project];
        }
        OpenPicker(type, multiple);
        await InvokeAsync(StateHasChanged);
    }
    private async Task UploadImageAsync(InputFileChangeEventArgs args) => await UploadAndInsertAsync(args.File, "image");
    private async Task UploadVideoAsync(InputFileChangeEventArgs args) => await UploadAndInsertAsync(args.File, "video");
    private async Task UploadAndInsertAsync(IBrowserFile file, string expectedType)
    {
        if (isSaving || Data.Project is null) return;
        var valid = expectedType == "image"
            ? file.ContentType is "image/jpeg" or "image/png" or "image/webp" or "image/gif"
            : file.ContentType is "video/mp4" or "video/webm";
        if (!valid) { errors.Clear(); errors.Add(expectedType == "image" ? "Sélectionnez une image JPG, PNG, WebP ou GIF." : "Sélectionnez une vidéo MP4 ou WebM."); return; }

        isSaving = true;
        errors.Clear();
        successMessage = null;
        try
        {
            var media = await MediaApiService.UploadAsync(file, Data.Project.Id);
            await InsertMediaAsync([media]);
            successMessage = expectedType == "image" ? "Image envoyée et insérée dans la documentation." : "Vidéo envoyée et insérée dans la documentation.";
        }
        catch (Exception exception) { errors.Add(exception.Message); }
        finally { isSaving = false; }
    }
    private void ClosePicker() => pickerOpen = false;
    private async Task InsertMediaAsync(IReadOnlyList<MediaApiDto> selected)
    {
        var fragments = selected.Select(item => (Item: item, Url: ResolveMediaUrl(item.PublicUrl))).Where(x => !string.IsNullOrWhiteSpace(x.Url)).Select(x => x.Item.MediaType switch
        {
            "image" => $"<img src=\"{x.Url}\" data-media-id=\"{x.Item.Id}\" alt=\"{x.Item.AltText}\" data-caption=\"{x.Item.Caption}\">",
            "video" => $"<video controls src=\"{x.Url}\" data-media-id=\"{x.Item.Id}\" title=\"{x.Item.Caption}\"></video>",
            _ => $"<p><a href=\"{x.Url}\" data-media-id=\"{x.Item.Id}\" target=\"_blank\" rel=\"noopener\">{x.Item.OriginalFilename}</a></p>"
        }).ToArray();
        if (fragments.Length > 0) { html += pickerMultiple ? $"<figure class=\"document-gallery\">{string.Join(string.Empty, fragments)}</figure>" : fragments[0]; await OnHtmlChanged(html); }
        pickerOpen = false;
    }

    private string? ResolveMediaUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return null;
        if (Uri.TryCreate(value, UriKind.Absolute, out var absolute)) return absolute.ToString();
        return Uri.TryCreate(Configuration["Api:BaseUrl"], UriKind.Absolute, out var apiBase) ? new Uri(apiBase, value).ToString() : value;
    }

    private async Task RunAsync(Func<Task> action)
    {
        if (isSaving) return; isSaving = true; errors.Clear(); successMessage = null;
        try { await action(); }
        catch (ProjectApiException exception) { errors.AddRange(exception.Errors); }
        catch { errors.Add("L’opération n’a pas pu être effectuée. Les modifications locales sont conservées."); }
        finally { isSaving = false; }
    }

    private DotNetObjectReference<ProjectDocumentationEditor>? mediaPickerReference;
    public void Dispose() => mediaPickerReference?.Dispose();
}
