@using FrontEnd.Models

<button class="admin-project-card" type="button" @onclick="() => OnSelected.InvokeAsync(Project)">
    <img src="@Project.ImageUrl" alt="Aperçu du projet @Project.Name" />
    <span class="admin-project-card__body">
        <span class="admin-project-card__type">@Project.Type</span>
        <strong>@Project.Name</strong>
        <span class="admin-project-card__description">@Project.Description</span>
        <span class="admin-project-card__technologies">
            @foreach (var technology in Project.Technologies)
            {
                <span>@technology</span>
            }
        </span>
    </span>
</button>

@code {
    [Parameter, EditorRequired] public AdminProject Project { get; set; } = default!;
    [Parameter] public EventCallback<AdminProject> OnSelected { get; set; }
}
