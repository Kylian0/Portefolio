@if (Variant == "compact")
{
    <article class="project-card project-card--compact">
        <a class="project-card__compact-link" href="@DetailUrl" aria-label="Découvrir le projet @Title">
            <img class="project-card__image" src="@ImageUrl" alt="@ImageAlt" />
            <h2>@Title</h2>
        </a>
    </article>
}
else
{
<article class="project-card @(Variant == "gallery" ? "project-card--gallery" : null)">
    <div class="project-card__media">
        <img class="project-card__image" src="@ImageUrl" alt="@ImageAlt" />
        @if (!string.IsNullOrEmpty(Category))
        {
            <span class="project-card__category">@Category</span>
        }
    </div>
    <div class="project-card__content">
        <h2>@Title</h2>
        <p>@Description</p>
        @if (ProjectTechnologies.Count > 0)
        {
            <ul id="@TechnologyListId" class="project-card__technologies" aria-label="Technologies utilisées">
                @foreach (var technology in VisibleProjectTechnologies)
                {
                    <li class="@(technology.IsPrimary ? "project-card__technology--primary" : null)">
                        @if (technology.IsPrimary)
                        {
                            <span class="project-card__primary-marker" title="Technologie principale" aria-label="Technologie principale">★</span>
                        }
                        <span>@GetTechnologyName(technology)</span>
                        @if (!string.IsNullOrWhiteSpace(technology.CategoryName))
                        {
                            <small>@technology.CategoryName</small>
                        }
                    </li>
                }
            </ul>
            @if (ProjectTechnologies.Count > VisibleTechnologyCount)
            {
                <button type="button" class="project-card__technologies-toggle" aria-expanded="@showAllTechnologies" aria-controls="@TechnologyListId" @onclick="ToggleTechnologies">
                    @(showAllTechnologies ? "Réduire" : $"+ {ProjectTechnologies.Count - VisibleTechnologyCount} autre(s)")
                </button>
            }
        }
        else if (Technologies.Count > 0)
        {
            <ul id="@TechnologyListId" class="project-card__technologies" aria-label="Technologies utilisées">
                @foreach (var technology in VisibleLegacyTechnologies)
                {
                    <li>@technology</li>
                }
            </ul>
            @if (Technologies.Count > VisibleTechnologyCount)
            {
                <button type="button" class="project-card__technologies-toggle" aria-expanded="@showAllTechnologies" aria-controls="@TechnologyListId" @onclick="ToggleTechnologies">
                    @(showAllTechnologies ? "Réduire" : $"+ {Technologies.Count - VisibleTechnologyCount} autre(s)")
                </button>
            }
        }
        @if (TechnologyLoadFailed)
        {
            <small class="project-card__technology-error" role="status">Technologies temporairement indisponibles.</small>
        }
        <a class="project-card__link" href="@DetailUrl" aria-label="Découvrir le projet @Title">
            Voir la documentation <span aria-hidden="true">→</span>
        </a>
    </div>
</article>
}

@code {
    private const int VisibleTechnologyCount = 3;
    private bool showAllTechnologies;

    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Description { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string DetailUrl { get; set; } = string.Empty;
    [Parameter] public string ImageUrl { get; set; } = "images/project-placeholder.svg";
    [Parameter] public string ImageAlt { get; set; } = "Illustration temporaire du projet";
    [Parameter] public string? Category { get; set; }
    [Parameter] public IReadOnlyList<string> Technologies { get; set; } = [];
    [Parameter] public IReadOnlyList<ProjectTechnologyApiDto> ProjectTechnologies { get; set; } = [];
    [Parameter] public bool TechnologyLoadFailed { get; set; }
    [Parameter] public string? Variant { get; set; }

    private string TechnologyListId => $"project-technologies-{Math.Abs(HashCode.Combine(Title, DetailUrl))}";
    private IEnumerable<ProjectTechnologyApiDto> VisibleProjectTechnologies => showAllTechnologies ? ProjectTechnologies : ProjectTechnologies.Take(VisibleTechnologyCount);
    private IEnumerable<string> VisibleLegacyTechnologies => showAllTechnologies ? Technologies : Technologies.Take(VisibleTechnologyCount);

    private void ToggleTechnologies() => showAllTechnologies = !showAllTechnologies;
    private static string GetTechnologyName(ProjectTechnologyApiDto technology) =>
        string.IsNullOrWhiteSpace(technology.TechnologyName) ? "Technologie non renseignée" : technology.TechnologyName;
}
