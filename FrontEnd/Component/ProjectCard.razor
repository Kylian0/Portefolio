<article class="project-card @(Variant == "gallery" ? "project-card--gallery" : null)">
    <div class="project-card__media">
        <img class="project-card__image" src="@ImageUrl" alt="@ImageAlt" />
        @if (!string.IsNullOrEmpty(Category))
        {
            <span class="project-card__category">@Category</span>
        }
    </div>
    <div class="project-card__content">
        <h2>@Title</h2>
        <p>@Description</p>
        @if (Technologies.Count > 0)
        {
            <ul class="project-card__technologies" aria-label="Technologies utilisées">
                @foreach (var technology in Technologies)
                {
                    <li>@technology</li>
                }
            </ul>
        }
        <a class="project-card__link" href="@DetailUrl" aria-label="Découvrir le projet @Title">
            Voir la documentation <span aria-hidden="true">→</span>
        </a>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Description { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string DetailUrl { get; set; } = string.Empty;

    [Parameter]
    public string ImageUrl { get; set; } = "images/project-placeholder.svg";

    [Parameter]
    public string ImageAlt { get; set; } = "Illustration temporaire du projet";

    [Parameter]
    public string? Category { get; set; }

    [Parameter]
    public IReadOnlyList<string> Technologies { get; set; } = [];

    [Parameter]
    public string? Variant { get; set; }
}
