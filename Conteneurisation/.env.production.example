# Copiez ce fichier vers .env.production sur le VPS.
# Ne versionnez jamais le fichier .env.production obtenu.

# Domaine et contact ACME de Caddy
DOMAIN=portfolio-garnier.fr
CADDY_EMAIL=admin@example.com

# Configuration des médias
MEDIA_MAX_FILE_SIZE_BYTES=26214400
MEDIA_MAX_REQUEST_SIZE_BYTES=104857600
MEDIA_MAX_FILES_PER_UPLOAD=20

# Compte administrateur initial
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_WITH_A_LONG_RANDOM_ADMIN_PASSWORD

# Base de données de production
MYSQL_DATABASE=portfolio_db
MYSQL_USER=portfolio_app
MYSQL_PASSWORD=CHANGE_ME_WITH_A_RANDOM_DATABASE_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_WITH_A_DIFFERENT_RANDOM_ROOT_PASSWORD
